# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored, but note it IS bundled into packaged builds
# (electron-builder extraResources), so do NOT publish builds containing
# secret keys to a public place.

# --- Supabase (cloud sync / auth) ---
# The anon key is safe to ship publicly as long as Row-Level Security is on.
SUPABASE_URL=
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- OpenRouter (AI: Prompt Boost / Coach) ---
# Used as a fallback when no key is set in the app's Settings. Bundling this in a
# build lets you avoid re-entering it on a new machine — but anyone with the build
# can read it, so keep such builds private.
OPENROUTER_API_KEY=
